@tailwind base;
@tailwind components;
@tailwind utilities;

/*
  Define CSS variables that mirror the colours and sizes from the
  provided HTML mockup. These variables are consumed in
  tailwind.config.ts so that utility classes like `bg-primary` and
  `text-secondary` resolve to the correct values.
*/
:root {
  /* Brand palette */
  --color-primary: #055d2c; /* rich green reminiscent of industry */
  --color-secondary: #b38600; /* warm golden accent */
  --color-accent: #e8f5e9; /* light green background for cards */
  --color-dark: #0a0e14; /* almost black for text and footers */
  --color-light: #ffffff; /* white backgrounds */
  --color-muted: #f5f7fa; /* light grey for subtle backgrounds */
  --color-success: #10b981; /* success green used in icons */
  --color-warning: #f59e0b; /* warning yellow used in highlights */

  /* Typography */
  --font-inter: 'Inter', sans-serif;
}

body {
  @apply font-sans text-dark bg-light antialiased;
}

/* Utility classes outside of Tailwind's scope */
.container {
  @apply mx-auto px-4 sm:px-6 lg:px-8;
}